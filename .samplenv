# IMPORTANT: This is a sample template provided as a starting point for your .env file

# Copy this file into a file named .env and edit it as needed

# database configs
MONGO_URI="mongodb://localhost:27017"
DB_NAME="eventsref_dev"
MOCK_DB="false"
# change the JWT key to any random string but keep it a secret. 
JWT_SECRET_KEY="any-string" 

# server config
DEBUG="true"

# AWS Setup
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-north-1        
SES_SENDER_EMAIL=your_verified@email.com


# Telegram Bot Setup
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
